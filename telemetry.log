871abff8cd0a80d6664ca144cbe1a8a271ecd30","documentUri":"file:///workspaces/aireli-lecture-task/apps/api/src/models/User.ts","documentId":13,"operation":"add","value":"  // 1. Validate input\n  if (!email || !input.password) {\n    throw new Error(\"Missing email or password\");\n  }\n\n  if (input.password.length < 8) {\n    throw new Error(\"Password must be at least 8 characters\");\n  }\n\n  // 2. Check if user exists\n  const existingUser = await prisma.platformUser.findUnique({\n    where: { email },\n  });\n\n  if (existingUser) {\n    throw new Error(\"User already exists\");\n  }\n\n  // 3. Hash password\n  const passwordHash = await bcrypt.hash(input.password, 12);\n\n  // 4. Store user\n  const user = await prisma.platformUser.create({\n    data: {\n      email,\n      passwordHash,\n    },\n  });\n\n  // 5. Return safe object\n  return {\n    id: user.id,\n    email: user.email,\n    createdAt: user.createdAt,\n  };\n}","rangeOffset":"342","rangeLength":"0","rangestart_line":"13","rangestart_character":"2","rangeend_line":"13","rangeend_character":"2"},{"codespaceName":"sturdy-trout-4j4pgpggr7qgfqrwj","eventName":"DocumentChangeEvent","eventTime":1773822554331,"sessionId":"605592d0-f682-4a9d-bd5d-789ddcbbb51a1773820002308","machineId":"1aeea70136598a04a67cb4c9e871abff8cd0a80d6664ca144cbe1a8a271ecd30","documentUri":"file:///workspaces/aireli-lecture-task/apps/api/src/models/User.ts","documentId":13,"operation":"delete","value":"","rangeOffset":"1076","rangeLength":"1","rangestart_line":"48","rangestart_character":"0","rangeend_line":"48","rangeend_character":"1"},{"codespaceName":"sturdy-trout-4j4pgpggr7qgfqrwj","eventName":"DocumentChangeEvent","eventTime":1773822554585,"sessionId":"605592d0-f682-4a9d-bd5d-789ddcbbb51a1773820002308","machineId":"1aeea70136598a04a67cb4c9e871abff8cd0a80d6664ca144cbe1a8a271ecd30","documentUri":"file:///workspaces/aireli-lecture-task/apps/api/src/models/User.ts","documentId":13,"operation":"delete","value":"","rangeOffset":"1